@model LandonWebsite06.Models.Companies
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
    ViewBag.Title = "Remove Exhibitor";
}

<div class="page-header">
    <h1><i class="bi bi-building-x me-2"></i>Remove Exhibitor</h1>
    <a asp-controller="Companies" asp-action="ListAll" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Exhibitors
    </a>
</div>

<div class="form-wrapper">
    <div class="alert alert-danger mb-4">
        <i class="bi bi-exclamation-triangle me-2"></i>
        This action cannot be undone. The company will be permanently removed from the directory.
    </div>

    <div class="mb-4">
        <p class="mb-1"><strong>Company:</strong> @Model.companyName</p>
        <p class="mb-1">
            <strong>Booth:</strong>
            <span class="booth-badge"><i class="bi bi-geo-alt me-1"></i>Booth @Model.boothnumber</span>
        </p>
    </div>

    <form asp-action="Remove" asp-controller="Companies" method="post">
        <input type="hidden" name="id" value="@Model.ID" />
        <div class="d-flex gap-2">
            <input type="submit" value="Yes, Remove Exhibitor" class="btn btn-danger" />
            <a asp-controller="Companies" asp-action="ListAll" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
