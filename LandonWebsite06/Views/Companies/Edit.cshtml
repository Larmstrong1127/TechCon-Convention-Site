@model LandonWebsite06.Models.Companies
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
    ViewBag.Title = "Edit Exhibitor";
}

<!-- ── Page Header ──────────────────────────────────────── -->
<div class="page-header">
    <h1><i class="bi bi-pencil me-2"></i>Edit Exhibitor</h1>
    <a asp-controller="Companies" asp-action="ListAll" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Exhibitors
    </a>
</div>

<!-- ── Edit Company Form ────────────────────────────────── -->
<div class="form-wrapper">
    @using (Html.BeginForm("Edit", "Companies", FormMethod.Post))
    {
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        <!-- Hidden field preserves the ID so the controller knows which record to update -->
        @Html.HiddenFor(m => m.ID)

        <div class="form-group">
            <label asp-for="companyName">Company Name</label>
            <input asp-for="companyName" class="form-control" placeholder="Company name" />
            <span asp-validation-for="companyName" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="boothnumber">Booth Number</label>
            <input asp-for="boothnumber" class="form-control" placeholder="Booth number" />
            <span asp-validation-for="boothnumber" class="field-validation-error"></span>
        </div>

        <div class="d-flex gap-2 mt-4">
            <input type="submit" value="Save Changes" class="btn btn-primary" />
            <a asp-controller="Companies" asp-action="ListAll" class="btn btn-secondary">Cancel</a>
        </div>
    }
</div>
