@model IEnumerable<LandonWebsite06.Models.SpecialGuests>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
    ViewBag.Title = "Special Guests";
}

<div class="page-header">
    <h1><i class="bi bi-star-fill me-2"></i>Special Guests</h1>
    <a asp-controller="SpecialGuest" asp-action="Add" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add Guest
    </a>
</div>

@if (TempData["GuestSuccess"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>@TempData["GuestSuccess"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No special guests announced yet.
        <a asp-controller="SpecialGuest" asp-action="Add">Add the first guest!</a>
    </div>
}
else
{
    <div class="row">
        @foreach (var guest in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-start gap-3">
                            <div style="font-size:2.5rem; color:#4f46e5; flex-shrink:0;">
                                <i class="bi bi-person-circle"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h2 style="font-size:1.1rem; margin-bottom:0.15rem;">@guest.guestName</h2>
                                @if (!string.IsNullOrEmpty(guest.Title))
                                {
                                    <p style="color:#4f46e5; font-size:0.85rem; font-weight:600; margin-bottom:0.1rem;">
                                        @guest.Title
                                    </p>
                                }
                                @if (!string.IsNullOrEmpty(guest.Company))
                                {
                                    <p style="color:#64748b; font-size:0.82rem; margin-bottom:0.5rem;">
                                        <i class="bi bi-building me-1"></i>@guest.Company
                                    </p>
                                }
                                @if (!string.IsNullOrEmpty(guest.Bio))
                                {
                                    <p style="color:#4a5568; font-size:0.85rem; margin-bottom:0.75rem;">
                                        @guest.Bio
                                    </p>
                                }
                                <div class="d-flex gap-2">
                                    <a asp-controller="SpecialGuest" asp-action="Edit"
                                       asp-route-id="@guest.ID" class="btn btn-primary btn-sm">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </a>
                                    <a asp-controller="SpecialGuest" asp-action="Delete"
                                       asp-route-id="@guest.ID" class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash me-1"></i>Remove
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    <p class="text-muted small mt-2">@Model.Count() special guest(s) attending</p>
}
