@model LandonWebsite06.Models.SpecialGuests
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
    ViewBag.Title = "Add Special Guest";
}

<div class="page-header">
    <h1><i class="bi bi-person-plus me-2"></i>Add Special Guest</h1>
    <a asp-controller="SpecialGuest" asp-action="ViewAll" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Guests
    </a>
</div>

<div class="form-wrapper">
    <form asp-action="Add" asp-controller="SpecialGuest" method="post">
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        <div class="form-group">
            <label asp-for="guestName">Full Name</label>
            <input asp-for="guestName" class="form-control" placeholder="e.g. Dr. Sarah Chen" />
            <span asp-validation-for="guestName" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Title">Title / Role</label>
            <input asp-for="Title" class="form-control" placeholder="e.g. Director of AI Research" />
            <span asp-validation-for="Title" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Company">Company / Organization</label>
            <input asp-for="Company" class="form-control" placeholder="e.g. Microsoft" />
            <span asp-validation-for="Company" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Bio">Bio</label>
            <textarea asp-for="Bio" class="form-control" rows="3"
                      placeholder="Brief biography..." style="resize:vertical;"></textarea>
            <span asp-validation-for="Bio" class="field-validation-error"></span>
        </div>

        <div class="d-flex gap-2 mt-4">
            <input type="submit" value="Add Guest" class="btn btn-primary" />
            <a asp-controller="SpecialGuest" asp-action="ViewAll" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
