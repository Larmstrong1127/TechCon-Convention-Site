@model LandonWebsite06.Models.SpecialGuests
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
    ViewBag.Title = "Remove Guest";
}

<div class="page-header">
    <h1><i class="bi bi-person-x me-2"></i>Remove Special Guest</h1>
    <a asp-controller="SpecialGuest" asp-action="ViewAll" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Guests
    </a>
</div>

<div class="form-wrapper">
    <div class="alert alert-danger mb-4">
        <i class="bi bi-exclamation-triangle me-2"></i>
        This action cannot be undone. The guest will be permanently removed.
    </div>

    <div class="mb-4">
        <p class="mb-1"><strong>Name:</strong> @Model.guestName</p>
        @if (!string.IsNullOrEmpty(Model.Title))
        {
            <p class="mb-1"><strong>Title:</strong> @Model.Title</p>
        }
        @if (!string.IsNullOrEmpty(Model.Company))
        {
            <p class="mb-1"><strong>Company:</strong> @Model.Company</p>
        }
    </div>

    <form asp-action="Delete" asp-controller="SpecialGuest" method="post">
        <input type="hidden" asp-for="ID" />
        <div class="d-flex gap-2">
            <input type="submit" value="Yes, Remove Guest" class="btn btn-danger" />
            <a asp-controller="SpecialGuest" asp-action="ViewAll" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
